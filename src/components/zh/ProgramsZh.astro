---
import { CheckCircle2Icon, ClockIcon } from "@lucide/astro";
import { additionalZh, detailsZh, timelineZh } from "../../libs/program";
---

<section id="programs" class="bg-white py-24 lg:py-32">
    <article class="mx-auto max-w-7xl px-6 space-y-12">
        <header class="mx-auto max-w-5xl text-center space-y-5">
            <span
                class="inline-block rounded-full bg-secondary/10 px-4 py-1.5 text-xs font-semibold text-secondary"
            >
                节目单
            </span>
            <h2
                class="text-3xl font-bold tracking-tight text-primary sm:text-4xl lg:text-5xl text-balance"
            >
                项目简介
            </h2>
            <p
                class="text-base leading-relaxed text-dark lg:text-lg text-pretty w-full text-start"
            >
                “自学英语大师班”是一场时长3小时的互动课程，旨在通过实用的自学策略、免费/低成本资源的高效利用以及科学的备考方法，帮助学习者达到欧洲语言共同参考框架（CEFR）B2至C1级别。参与者还将学习如何运用人工智能工具，并发现持续进步的“秘诀”。每位学员都将获得《自学英语》电子书，该书可作为持续学习的全面指南。
            </p>
        </header>

        <div class="flex flex-col gap-16 lg:flex-row lg:gap-20">
            <div
                class="flex flex-col items-center lg:w-85 lg:shrink-0 lg:items-start"
            >
                <figure class="relative mb-4">
                    <div
                        class="absolute -inset-3 rounded-full bg-secondary/15 blur-2xl"
                    >
                    </div>
                    <img
                        src="/professor.jpeg"
                        alt="Profesor Martin Zale Winkler"
                        class="relative rounded-2xl border-2 border-primary/10 object-cover shadow-xl size-65"
                    />
                </figure>
                <h3 class="my-2 text-2xl font-bold text-primary">
                    马丁·扎勒·温克勒教授
                </h3>
                <p
                    class="text-center text-sm font-semibold text-secondary lg:text-left"
                >
                    加州大学伯克利分校毕业生
                </p>
                <p
                    class="mt-1 text-center text-sm font-semibold text-dark lg:text-left"
                >
                    加州认证教师
                </p>
                <p
                    class="mt-2 text-center text-sm leading-relaxed text-dark lg:text-left"
                >
                    30多年来，我们一直致力于帮助全球各地的学生和专业人士取得成功。
                </p>

                <ul class="mt-4 flex w-full flex-col gap-4">
                    {
                        detailsZh.map((item) => (
                            <li class="flex items-start gap-3">
                                <figure class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                                    <item.icon class="size-5 text-primary" />
                                </figure>
                                <div>
                                    <h4 class="text-sm font-bold tracking-wide text-foreground">
                                        {item.label}
                                    </h4>
                                    <p class="text-xs leading-relaxed text-dark">
                                        {item.value}
                                    </p>
                                </div>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <div class="flex-1 space-y-10">
                <header class="space-y-2">
                    <h3 class="text-xl font-bold text-primary">
                        时间安排：3小时的大师班
                    </h3>
                    <p class="text-sm text-dark">
                        每个模块的设计都旨在最大限度地提升您的学习效果。
                    </p>
                </header>

                <div class="relative">
                    <div
                        class="absolute left-4.75 top-2 bottom-2 w-0.5 bg-border"
                    >
                    </div>

                    <ul class="flex flex-col gap-8">
                        {
                            timelineZh.map((mod, i) => (
                                <li class="group relative flex gap-5">
                                    <div class="relative z-10 flex size-10 shrink-0 items-center justify-center rounded-full border border-secondary bg-background text-sm font-bold text-secondary shadow-sm transition-all group-hover:bg-secondary group-hover:text-white">
                                        {i + 1}
                                    </div>
                                    <article class="flex-1 rounded-xl border border-border bg-white p-5 shadow-sm transition-all duration-300 group-hover:shadow-lg group-hover:border-secondary/30 space-y-4">
                                        <h4 class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 text-base font-bold text-primary">
                                            <div class="flex flex-col md:flex-row items-start gap-2">
                                                <div class="flex items-center gap-1">
                                                    <mod.icon
                                                        class={`size-4 ${mod.classIcon}`}
                                                    />
                                                    {mod.hour}
                                                </div>
                                                <span class="hidden md:block mx-1">
                                                    –
                                                </span>
                                                {mod.title}
                                            </div>
                                            <span class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">
                                                <ClockIcon class="size-3" />
                                                {mod.time}
                                            </span>
                                        </h4>
                                        <ul class="space-y-2 text-sm text-dark">
                                            {mod.bullets.map((item) => (
                                                <li class="flex items-start gap-2">
                                                    <span class="mt-2 size-1.5 rounded-full bg-secondary shrink-0" />
                                                    <span>{item}</span>
                                                </li>
                                            ))}
                                        </ul>
                                        <figure class="flex items-center gap-1.5 text-xs font-medium text-secondary">
                                            <CheckCircle2Icon class="size-3.5" />
                                            <figcaption>
                                                大师班包含以下内容
                                            </figcaption>
                                        </figure>
                                    </article>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div class="relative">
                    <ul class="flex flex-col gap-8">
                        {
                            additionalZh.map((mod) => (
                                <li class="group relative flex gap-5">
                                    <article class="flex-1 rounded-xl border border-border bg-white p-5 shadow-sm transition-all duration-300 group-hover:shadow-lg group-hover:border-primary/30 space-y-2">
                                        <div class="flex items-center gap-3">
                                            <h4 class="flex items-center gap-2 text-base font-bold text-primary">
                                                {mod.icon && (
                                                    <mod.icon
                                                        class={`size-4 ${mod.classIcon}`}
                                                    />
                                                )}
                                                {mod.title}
                                            </h4>
                                        </div>
                                        <ul class="space-y-2 text-sm text-dark">
                                            {mod.bullets.map((item) => (
                                                <li class="flex items-start gap-2">
                                                    <span class="mt-2 size-1.5 rounded-full bg-primary shrink-0" />
                                                    <span>{item}</span>
                                                </li>
                                            ))}
                                        </ul>
                                    </article>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </article>
</section>
