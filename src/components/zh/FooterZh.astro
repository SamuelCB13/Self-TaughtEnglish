---
import {
    BookOpenIcon,
    LinkedinIcon,
    MailIcon,
} from "@lucide/astro";
import { footerZh } from "../../libs/footer";

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-white">
    <section class="mx-auto max-w-7xl px-6 py-4 lg:py-8 space-y-5">
        <article
            class="flex items-center gap-10 justify-evenly md:justify-between"
        >
            <div>
                <ul class="flex flex-col md:flex-row gap-4">
                    {
                        footerZh.map((item) => (
                            <a
                                href={item.href}
                                class="text-sm font-bold text-dark transition-colors hover:text-primary"
                            >
                                {item.value}
                            </a>
                        ))
                    }
                </ul>
            </div>

            <div>
                <ul class="flex flex-col md:flex-row gap-4">
                    <li>
                        <a
                            href="https://www.linkedin.com/in/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center gap-2 text-sm font-bold text-dark transition-colors hover:text-primary"
                        >
                            <LinkedinIcon class="size-4" />
                            领英
                        </a>
                    </li>
                    <li>
                        <a
                            href="mailto:"
                            class="flex items-center gap-2 text-sm font-bold text-dark transition-colors hover:text-primary"
                        >
                            <MailIcon class="size-4" />
                            电子邮件
                        </a>
                    </li>
                </ul>
            </div>
        </article>

        <div class="grow border-t border-border"></div>

        <article
            class="flex flex-col md:flex-row items-center md:justify-evenly gap-4"
        >
            <div class="flex items-center justify-center gap-2.5">
                <div
                    class="flex size-9 items-center justify-center rounded-lg bg-primary"
                >
                    <BookOpenIcon class="size-5 text-white" />
                </div>
                <span class="text-lg font-black">自学英语</span>
            </div>
            <p class="text-sm leading-relaxed text-dark text-center">
                加州大学伯克利分校证书 • 加州教师资格证 • 30余年从业经验
            </p>
        </article>

        <div class="grow border-t border-border"></div>

        <article
            class="flex flex-col items-center gap-4 md:flex-row md:justify-between"
        >
            <p class="text-xs text-dark">
                {year} 马丁·扎勒·温克勒教授。保留所有权利。
            </p>
            <p class="text-xs text-dark">
                英语大师班 | 自学英语 | 加州大学伯克利分校教授
            </p>
        </article>
    </section>
</footer>
