---
import {
    ArrowRightIcon,
    BookOpenIcon,
    GlobeIcon,
    GraduationCapIcon,
    MailIcon,
    SendIcon,
} from "@lucide/astro";
---

<section
    id="contact"
    class="relative overflow-hidden bg-primary py-24 lg:py-32"
>
    <article
        class="relative z-10 mx-auto grid max-w-7xl grid-cols-1 gap-14 px-6 lg:grid-cols-2 lg:items-center"
    >
        {/* LEFT SIDE */}
        <div class="space-y-10">
            <header class="space-y-5 text-center">
                <span
                    class="inline-block rounded-full border border-secondary/30 bg-secondary/10 px-5 py-2 text-xs font-semibold text-secondary backdrop-blur-md tracking-widest"
                >
                    立即行动
                </span>

                <h2
                    class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl text-balance"
                >
                    立即预约。
                </h2>

                <p
                    class="max-w-xl text-base leading-relaxed text-light/70 lg:text-lg text-pretty"
                >
                    不要再犹豫了。立即报名参加大师班，通过这一行之有效的方法，迈出精通英语的第一步。
                </p>
            </header>

            {/* Benefits */}
            <ul class="grid grid-cols-1 gap-4 sm:grid-cols-3 lg:grid-cols-1">
                <li
                    class="flex items-center gap-4 rounded-xl border border-white/10 bg-white/5 px-5 py-5 backdrop-blur-sm"
                >
                    <GraduationCapIcon class="size-7 text-secondary shrink-0" />

                    <div>
                        <p class="font-semibold text-white">
                            加州大学伯克利分校证书
                        </p>

                        <p class="text-sm text-white/60">
                            国际学术认可
                        </p>
                    </div>
                </li>

                <li
                    class="flex items-center gap-4 rounded-xl border border-white/10 bg-white/5 px-5 py-5 backdrop-blur-sm"
                >
                    <BookOpenIcon class="size-7 text-secondary shrink-0" />

                    <div>
                        <p class="font-semibold text-white">含电子书</p>

                        <p class="text-sm text-white/60">
                            辅助学习资料
                        </p>
                    </div>
                </li>

                <li
                    class="flex items-center gap-4 rounded-xl border border-white/10 bg-white/5 px-5 py-5 backdrop-blur-sm"
                >
                    <GlobeIcon class="size-7 text-secondary shrink-0" />

                    <div>
                        <p class="font-semibold text-white">
                            30余年的经验
                        </p>

                        <p class="text-sm text-white/60">
                            行之有效的教学方法
                        </p>
                    </div>
                </li>
            </ul>

            {/* Buttons */}
            <div
                class="flex flex-col items-center justify-center gap-4 sm:flex-row"
            >
                <a
                    href="https://www.linkedin.com/in/martin-zale-winkler/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 rounded-lg group bg-secondary text-white py-3 px-5 text-base font-bold shadow-secondary/25 hover:bg-secondary/90 hover:shadow-lg hover:shadow-secondary/30 transition-all cursor-pointer"
                >
                    <ArrowRightIcon
                        class="size-5 transition-transform group-hover:translate-x-1"
                    />

                    在 LinkedIn 上给马丁发消息
                </a>

                <a
                    href="mailto:professorMartin2026@gmail.com"
                    class="flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 text-white py-3 px-5 text-base font-semibold backdrop-blur-sm hover:bg-white/20 transition-all cursor-pointer"
                >
                    <MailIcon class="size-5" />

                    邮寄预订
                </a>
            </div>
        </div>

        {/* RIGHT SIDE - FORM */}
        <div
            class="rounded-2xl border border-white/10 bg-white/5 p-6 sm:p-8 backdrop-blur-md shadow-2xl"
        >
            <div class="mb-8">
                <h3 class="text-2xl font-bold text-white">联系表单</h3>

                <p class="mt-2 text-sm text-white/60">
                    请填写表格，我们将尽快与您联系。
                </p>
            </div>

            <form
                class="space-y-5"
                action="https://formsubmit.co/professorMartin2026@gmail.com"
                method="POST"
            >
                <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                    <div class="flex flex-col gap-2">
                        <label
                            for="name"
                            class="text-xs font-semibold uppercase tracking-widest text-white/60"
                        >
                            姓名
                        </label>

                        <input
                            type="text"
                            id="name"
                            name="name"
                            placeholder="您的全名"
                            class="rounded-lg border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/30 outline-none focus:border-secondary/60 transition-colors"
                        />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="email"
                            class="text-xs font-semibold uppercase tracking-widest text-white/60"
                        >
                            电子邮件
                        </label>

                        <input
                            type="email"
                            id="email"
                            name="email"
                            placeholder="your@email.com"
                            class="rounded-lg border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/30 outline-none focus:border-secondary/60 transition-colors"
                        />
                    </div>

                    <div class="flex flex-col gap-2 sm:col-span-2">
                        <label
                            for="institution"
                            class="text-xs font-semibold uppercase tracking-widest text-white/60"
                        >
                            机构 / 公司
                        </label>

                        <input
                            type="text"
                            id="institution"
                            name="institution"
                            placeholder="贵组织的名称"
                            class="rounded-lg border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/30 outline-none focus:border-secondary/60 transition-colors"
                        />
                    </div>

                    <div class="flex flex-col gap-2 sm:col-span-2">
                        <label
                            for="message"
                            class="text-xs font-semibold uppercase tracking-widest text-white/60"
                        >
                            消息
                        </label>

                        <textarea
                            id="message"
                            name="message"
                            rows={5}
                            placeholder="请告诉我们您对大师班感兴趣的原因..."
                            class="resize-none rounded-lg border border-white/15 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/30 outline-none focus:border-secondary/60 transition-colors"
                        ></textarea>
                    </div>

                    <input type="hidden" name="_captcha" value="false" />
                    <input type="hidden" name="_next" value="/thanks" />
                </div>

                <button
                    type="submit"
                    class="mt-2 flex w-full items-center justify-center gap-2 rounded-lg bg-secondary px-6 py-3 text-base font-bold text-white shadow-secondary/25 hover:bg-secondary/90 hover:shadow-lg hover:shadow-secondary/30 transition-all cursor-pointer"
                >
                    <SendIcon class="size-5" />

                    发送消息
                </button>
            </form>
        </div>
    </article>
</section>
