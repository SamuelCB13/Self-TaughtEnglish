---
import { ArrowRightIcon, ChevronDownIcon, PlayIcon, XIcon } from "@lucide/astro/icons";
import { statsZh, badgesZh } from "../../libs/hero";
---

<section
    id="hero"
    class="relative flex flex-col items-center justify-center xl:min-h-dvh w-full overflow-hidden"
>
    <div class="absolute inset-0 z-0">
        <img src="/hero-bg.jpg" alt="" class="object-cover w-full h-full" />
        <div class="absolute inset-0 bg-primary/90"></div>
        <div
            class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(255,102,0,0.12)_0%,transparent_60%)]"
        >
        </div>
    </div>

    <ul class="absolute right-6 top-24 z-20 hidden flex-col gap-2 lg:flex">
        {
            badgesZh.map((badge) => (
                <li class="flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 backdrop-blur-sm">
                    <badge.icon class="size-4 text-secondary" />
                    <span class={`text-xs ${badge.font} text-white`}>
                        {badge.label}
                    </span>
                </li>
            ))
        }
    </ul>

    <div
        class="relative z-10 mx-auto flex w-full max-w-7xl flex-col items-center gap-16 px-6 pb-12 pt-28 lg:flex-row lg:gap-20 lg:pt-32"
    >
        <article
            class="flex flex-1 flex-col items-center lg:items-start space-y-6"
        >
            <h1
                class="text-center font-extrabold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-left text-4xl lg:text-5xl xl:text-7xl text-balance"
            >
                大师班
                <span class="text-secondary">自学成才</span>
                英语
            </h1>

            <h2
                class="text-center font-semibold text-white text-lg xl:text-xl lg:text-left text-pretty"
            >
                了解如何通过自学更快、更高效且更经济地提高英语水平。
            </h2>

            <p
                class="max-w-xl text-center leading-relaxed text-light/70 lg:text-left text-sm lg:text-base xl:text-lg"
            >
                短短3小时内，马丁·扎勒·温克勒教授（加州大学伯克利分校毕业生、加州认证讲师）将结合《自学英语》电子书，为您讲解行之有效的学习技巧、革命性的AI工具，并提供通往CEFR B2-C1水平的一条清晰路径。
            </p>

            <div
                class="flex w-full flex-col items-center gap-4 sm:flex-row sm:justify-center lg:justify-start"
            >
                <a
                    href="#contact"
                    class="flex items-center gap-2 rounded-lg group bg-secondary text-white py-3 px-5 text-sm xl:text-base font-bold shadow-secondary/25 hover:bg-secondary/90 hover:shadow-lg hover:shadow-secondary/30 transition-all cursor-pointer"
                >
                    立即预约
                    <ArrowRightIcon
                        class="size-5 transition-transform group-hover:translate-x-1"
                    />
                </a>
                <a
                    href="#programs"
                    class="flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 text-white py-3 px-5 text-sm xl:text-base font-semibold backdrop-blur-sm hover:bg-white/20 transition-all cursor-pointer"
                >
                    查看节目
                </a>
            </div>

            <ul
                class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 w-full gap-4"
            >
                {
                    statsZh.map((stat) => (
                        <li class="flex flex-col items-center gap-1 rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
                            <h3 class="text-base xl:text-xl font-extrabold text-secondary">
                                {stat.value}
                            </h3>
                            <span class="text-xs font-medium text-white/60">
                                {stat.label}
                            </span>
                        </li>
                    ))
                }
            </ul>
        </article>

        {/* E-book Image */}
        <article
            class="flex flex-1 flex-col items-center lg:items-center gap-6"
        >
            <div class="relative shadow-2xl shadow-white/30 rounded-2xl">
                <div
                    class="absolute -inset-8 rounded-3xl bg-accent/15 blur-3xl"
                >
                </div>
                <div
                    class="absolute -inset-4 rounded-2xl bg-primary-foreground/5 blur-xl"
                >
                </div>
                <img
                    src="/ebook-cover.jpeg"
                    alt="Portada del e-book Self-Taught English"
                    class="relative w-96 xl:w-105 h-full rounded-2xl ring-1 ring-white/10"
                />
                <div
                    class="absolute -bottom-4 -right-4 flex items-center gap-2 rounded-xl bg-secondary px-4 py-3 shadow-lg"
                >
                    <span class="text-sm font-bold text-white"
                        >含电子书</span
                    >
                </div>
            </div>

            {/* Video Button */}
            <button
                id="open-video-btn"
                class="mt-4 flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 text-white py-3 px-5 text-sm xl:text-base font-semibold backdrop-blur-sm hover:bg-white/20 transition-all cursor-pointer"
            >
                <PlayIcon class="size-4 text-secondary" />
                观看演示视频
            </button>
        </article>

        {/* Video Modal */}
        <div
            id="video-modal"
            class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4"
        >
            <div
                class="relative w-full max-w-3xl rounded-2xl overflow-hidden shadow-2xl ring-1 ring-white/10"
            >
                <button
                    id="close-video-btn"
                    class="absolute top-3 right-3 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-black/60 text-white hover:bg-black/90 transition cursor-pointer"
                    aria-label="Close video"
                >
                    <XIcon class="size-4" />
                </button>
                <video
                    id="promo-video"
                    class="w-full aspect-video bg-black"
                    controls
                    preload="none"
                >
                    <source src="/video.mp4" type="video/mp4" />
                    您的浏览器不支持视频元素。
                </video>
            </div>
        </div>
    </div>
    <div class="relative z-10 flex animate-bounce flex-col items-center">
        <span class="text-xs font-medium text-white/50">了解更多</span>
        <ChevronDownIcon class="size-5 text-white/50" />
    </div>
</section>

<script>
    const openBtn = document.getElementById("open-video-btn");
    const closeBtn = document.getElementById("close-video-btn");
    const modal = document.getElementById("video-modal");
    const video = document.getElementById("promo-video") as HTMLVideoElement;

    openBtn?.addEventListener("click", () => {
        modal?.classList.remove("hidden");
        modal?.classList.add("flex");
        video?.play();
    });

    const closeModal = () => {
        modal?.classList.add("hidden");
        modal?.classList.remove("flex");
        video?.pause();
        if (video) video.currentTime = 0;
    };

    closeBtn?.addEventListener("click", closeModal);

    modal?.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
    });

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
    });
</script>
