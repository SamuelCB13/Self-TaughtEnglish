---
import {
    ChevronLeftIcon,
    ChevronRightIcon,
    QuoteIcon,
    StarIcon,
} from "@lucide/astro";
import { testimonials } from "../libs/testimonials";
---

<section id="testimonials" class="bg-white py-24 lg:py-32">
    <article class="mx-auto max-w-7xl px-6 space-y-12">
        <header class="mx-auto max-w-2xl text-center space-y-5">
            <span
                class="inline-block rounded-full bg-secondary/10 px-4 py-1.5 text-xs font-semibold text-secondary"
            >
                TESTIMONIALS
            </span>
            <h2
                class="text-3xl font-bold tracking-tight text-primary sm:text-4xl lg:text-5xl text-balance"
            >
                What our participants say
            </h2>
            <p
                class="text-base leading-relaxed text-dark lg:text-lg text-pretty"
            >
                Thousands of students and professionals have already transformed
                their English.
            </p>
        </header>

        <div class="relative">
            <div
                id="carousel-track"
                class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
            >
                {
                    testimonials.map((t) => (
                        <article class="snap-start shrink-0 w-80 sm:w-96 bg-white border border-border rounded-2xl shadow-md hover:border-secondary/50 transition-all duration-200 p-6 flex flex-col gap-4">
                            <div>
                                <QuoteIcon class="size-8 text-secondary/50" />
                            </div>
                            <div class="flex gap-0.5">
                                {Array.from({ length: 5 }).map((_, i) => (
                                    <StarIcon
                                        class={`size-4 ${i < t.estrellas ? "text-secondary fill-secondary" : "text-dark/50"}`}
                                    />
                                ))}
                            </div>
                            <p class="text-sm leading-relaxed text-gray-600 flex-1">
                                "{t.texto}"
                            </p>
                            <div class="flex items-center gap-3 pt-5 border-t border-gray-100">
                                <div class="size-9 rounded-full bg-primary flex items-center justify-center shrink-0">
                                    <span class="text-sm font-bold text-white">
                                        {t.nombre.charAt(0)}
                                    </span>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-sm font-semibold text-primary truncate">
                                        {t.nombre}
                                    </p>
                                    <p class="text-xs text-dark truncate">
                                        {t.rol} · {t.organizacion}
                                    </p>
                                </div>
                            </div>
                        </article>
                    ))
                }
            </div>

            <div class="flex justify-center gap-3 mt-8">
                <button
                    id="prev-btn"
                    aria-label="Anterior"
                    class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-gray-500 hover:border-secondary hover:text-secondary transition-colors duration-200 disabled:opacity-30 cursor-pointer disabled:cursor-not-allowed"
                >
                    <ChevronLeftIcon class="size-4" />
                </button>
                <button
                    id="next-btn"
                    aria-label="Siguiente"
                    class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-gray-500 hover:border-secondary hover:text-secondary transition-colors duration-200 disabled:opacity-30 cursor-pointer disabled:cursor-not-allowed"
                >
                    <ChevronRightIcon class="size-4" />
                </button>
            </div>
        </div>
    </article>
</section>

<script>
    const track = document.getElementById("carousel-track") as HTMLElement;
    const prevBtn = document.getElementById("prev-btn") as HTMLButtonElement;
    const nextBtn = document.getElementById("next-btn") as HTMLButtonElement;

    const getCardWidth = () => {
        const card = track.firstElementChild as HTMLElement;
        if (!card) return 0;
        return card.offsetWidth + parseInt(getComputedStyle(track).gap || "24");
    };

    nextBtn.addEventListener("click", () => {
        track.scrollBy({ left: getCardWidth(), behavior: "smooth" });
    });

    prevBtn.addEventListener("click", () => {
        track.scrollBy({ left: -getCardWidth(), behavior: "smooth" });
    });

    const updateButtons = () => {
        prevBtn.disabled = track.scrollLeft <= 0;
        nextBtn.disabled =
            track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;
    };

    track.addEventListener("scroll", updateButtons);
    updateButtons();
</script>
