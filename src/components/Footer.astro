---
import { BookOpenIcon, MailIcon } from "@lucide/astro";
import { footer } from "../libs/footer";

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-white">
    <section class="mx-auto max-w-7xl px-6 py-4 lg:py-8 space-y-5">
        <article
            class="flex items-center gap-10 justify-evenly md:justify-between"
        >
            <div>
                <ul class="flex flex-col md:flex-row gap-4">
                    {
                        footer.map((item) => (
                            <a
                                href={item.href}
                                class="text-sm font-bold text-dark transition-colors hover:text-primary"
                            >
                                {item.value}
                            </a>
                        ))
                    }
                </ul>
            </div>

            <div>
                <ul class="flex flex-col md:flex-row gap-4">
                    <li>
                        <a
                            href="https://www.linkedin.com/in/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center gap-2 text-sm font-bold text-dark transition-colors hover:text-primary"
                        >
                            <svg
                                preserveAspectRatio="xMidYMid"
                                viewBox="0 0 256 256"
                                class="size-4"
                                ><path
                                    d="M218.123 218.127h-37.931v-59.403c0-14.165-.253-32.4-19.728-32.4-19.756 0-22.779 15.434-22.779 31.369v60.43h-37.93V95.967h36.413v16.694h.51a39.907 39.907 0 0 1 35.928-19.733c38.445 0 45.533 25.288 45.533 58.186l-.016 67.013ZM56.955 79.27c-12.157.002-22.014-9.852-22.016-22.009-.002-12.157 9.851-22.014 22.008-22.016 12.157-.003 22.014 9.851 22.016 22.008A22.013 22.013 0 0 1 56.955 79.27m18.966 138.858H37.95V95.967h37.97v122.16ZM237.033.018H18.89C8.58-.098.125 8.161-.001 18.471v219.053c.122 10.315 8.576 18.582 18.89 18.474h218.144c10.336.128 18.823-8.139 18.966-18.474V18.454c-.147-10.33-8.635-18.588-18.966-18.453"
                                    fill="#0A66C2"></path></svg
                            >
                            LinkedIn
                        </a>
                    </li>
                    <li>
                        <a
                            href="mailto:"
                            class="flex items-center gap-2 text-sm font-bold text-dark transition-colors hover:text-primary"
                        >
                            <MailIcon class="size-4" />
                            Email
                        </a>
                    </li>
                </ul>
            </div>
        </article>

        <div class="grow border-t border-border"></div>

        <article
            class="flex flex-col md:flex-row items-center md:justify-evenly gap-4"
        >
            <div class="flex items-center justify-center gap-2.5">
                <div
                    class="flex size-9 items-center justify-center rounded-lg bg-primary"
                >
                    <BookOpenIcon class="size-5 text-white" />
                </div>
                <span class="text-lg font-black">Self-Taught English</span>
            </div>
            <p class="text-sm leading-relaxed text-dark text-center">
                UC Berkeley credential • California certification • 30+ years of
                experience
            </p>
        </article>

        <div class="grow border-t border-border"></div>

        <article
            class="flex flex-col items-center gap-4 md:flex-row md:justify-between"
        >
            <p class="text-xs text-dark">
                {year} Prof. Martin Zale Winkler. All rights reserved.
            </p>
            <p class="text-xs text-dark">
                Master Class English | Self-Study English | UC Berkeley
                Professor
            </p>
        </article>
    </section>
</footer>
