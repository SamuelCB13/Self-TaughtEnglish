---
import { ArrowRightIcon, CheckIcon } from "@lucide/astro";
import { packages } from "../lib/pricing";
---

<section id="prices" class="bg-background py-24 lg:py-32">
    <article class="mx-auto max-w-7xl px-6">
        <header class="mx-auto max-w-2xl text-center space-y-5">
            <span
                class="inline-block rounded-full bg-secondary/10 px-4 py-1.5 text-xs font-semibold text-secondary"
            >
                PRECIOS
            </span>
            <h2
                class="text-3xl font-bold tracking-tight text-primary sm:text-4xl lg:text-5xl text-balance"
            >
                Precios y paquetes
            </h2>
            <p
                class="text-base leading-relaxed text-dark lg:text-lg text-pretty"
            >
                Opciones flexibles para universidades, empresas y grupos de
                profesionales.
            </p>
        </header>

        <div class="mt-16 grid gap-8 lg:mt-20 lg:grid-cols-3">
            {
                packages.map((pkg) => (
                    <article
                        class={`relative flex flex-col overflow-hidden rounded-2xl transition-all duration-300 ${
                            pkg.highlight
                                ? "bg-primary text-light shadow-2xl shadow-primary/20 ring-2 ring-secondary lg:scale-105"
                                : "border border-border bg-white text-bold shadow-sm hover:shadow-xl"
                        }`}
                    >
                        {pkg.highlight && (
                            <div class="bg-secondary px-4 py-2 text-center text-xs font-bold text-background tracking-wider">
                                MÁS POPULAR
                            </div>
                        )}

                        <div class="flex flex-1 flex-col p-8">
                            <figure
                                class={`mb-6 flex size-12 items-center justify-center rounded-xl ${
                                    pkg.highlight
                                        ? "bg-light/10"
                                        : "bg-primary/10"
                                }`}
                            >
                                <pkg.icon
                                    class={`size-6 ${pkg.highlight ? "text-secondary" : "text-primary"}`}
                                />
                            </figure>

                            <header class="space-y-4">
                                <h3 class="text-xl font-bold">{pkg.title}</h3>

                                <span class="text-3xl font-extrabold">
                                    {pkg.price}
                                </span>

                                <p
                                    class={`text-xs mt-2 ${
                                        pkg.highlight
                                            ? "text-light/60"
                                            : "text-dark"
                                    }`}
                                >
                                    {pkg.priceNote}
                                </p>

                                <p
                                    class={`text-sm leading-relaxed ${
                                        pkg.highlight
                                            ? "text-light/75"
                                            : "text-dark"
                                    }`}
                                >
                                    {pkg.description}
                                </p>
                            </header>

                            {/* Divider */}
                            <div
                                class={`my-5 h-px ${pkg.highlight ? "bg-light/15" : "bg-border"}`}
                            />

                            <ul class="flex flex-1 flex-col gap-3">
                                {pkg.features.map((item) => (
                                    <li class="flex items-start gap-3 text-sm">
                                        <CheckIcon
                                            class={`mt-0.5 size-4 shrink-0 ${
                                                pkg.highlight
                                                    ? "text-secondary"
                                                    : "text-primary"
                                            }`}
                                        />
                                        <span
                                            class={
                                                pkg.highlight
                                                    ? "text-light/85"
                                                    : "text-dark"
                                            }
                                        >
                                            {item}
                                        </span>
                                    </li>
                                ))}
                            </ul>

                            <a
                                href=""
                                class={`flex items-center justify-center gap-2 text-white rounded-lg group py-2 px-4 text-sm font-bold transition-all cursor-pointer mt-6 ${
                                    pkg.highlight
                                        ? "bg-secondary shadow-lg shadow-secondary/25 hover:bg-secondary/90 hover:shadow-xl"
                                        : "bg-primary hover:bg-primary/90"
                                }`}
                            >
                                {pkg.cta}
                                <ArrowRightIcon class="size-5 transition-transform group-hover:translate-x-1" />
                            </a>
                        </div>
                    </article>
                ))
            }
        </div>

        <footer class="mt-10 text-center text-sm text-dark">
            Limite de asistencia: 40 personas en talleres. Tarifas especiales
            para seminarios grandes. Contáctanos para una cotización
            personalizada.
        </footer>
    </article>
</section>
