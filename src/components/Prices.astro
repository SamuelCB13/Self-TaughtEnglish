---
import {
    ArrowRightIcon,
    BriefcaseIcon,
    Building2Icon,
    MailIcon,
} from "@lucide/astro";
import { businessPricing } from "../libs/pricing";
---

<section id="prices" class="bg-background py-24 lg:py-32">
    <article class="mx-auto max-w-4xl px-6 space-y-12">
        <header class="mx-auto max-w-2xl text-center space-y-5">
            <span
                class="inline-block rounded-full bg-secondary/10 px-4 py-1.5 text-xs font-semibold text-secondary"
            >
                PRICES
            </span>
            <h2
                class="text-3xl font-bold tracking-tight text-primary sm:text-4xl lg:text-5xl text-balance"
            >
                Prices and packages
            </h2>
            <p
                class="text-base leading-relaxed text-dark lg:text-lg text-pretty"
            >
                Flexible options for universities, companies, and professional
                groups.
            </p>
        </header>

        <div class="flex flex-col gap-16 lg:gap-20">
            <div
                class="rounded-2xl border border-border bg-white p-8 shadow-sm lg:p-10 space-y-5"
            >
                <header class="flex items-center gap-4">
                    <figure
                        class="flex size-12 shrink-0 items-center justify-center rounded-xl bg-primary/10"
                    >
                        <Building2Icon class="size-6 text-primary" />
                    </figure>
                    <h3 class="text-2xl font-bold text-primary">
                        For Universities
                    </h3>
                </header>

                <div class="h-px bg-border"></div>

                <div class="space-y-3">
                    <h4 class="text-base font-semibold text-primary">
                        Price available upon request.
                    </h4>
                    <p class="text-sm leading-relaxed text-dark">
                        Special institutional rates tailored to the needs of
                        each university. Includes a 3-hour master class and a
                        SELF-TAUGHT ENGLISH e-book for each participant.
                    </p>
                </div>

                <a
                    href="mailto:"
                    class="inline-flex items-center gap-2 rounded-lg group bg-primary text-white py-2 px-4 text-sm font-bold shadow-primary/25 hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/30 transition-all cursor-pointer"
                >
                    Request information
                    <MailIcon
                        class="size-4 transition-transform group-hover:translate-x-1"
                    />
                </a>
            </div>

            <div
                class="overflow-hidden rounded-2xl border-2 border-primary bg-white shadow-xl shadow-primary/10"
            >
                <div class="bg-primary p-8 lg:p-10">
                    <header class="flex items-center gap-4">
                        <figure
                            class="flex size-12 shrink-0 items-center justify-center rounded-xl bg-white/10"
                        >
                            <BriefcaseIcon class="size-6 text-secondary" />
                        </figure>
                        <div>
                            <h3 class="text-2xl font-bold text-white">
                                For Businesses
                            </h3>
                            <p class="text-sm text-light/70">
                                Boost the English skills of your executives and
                                teams
                            </p>
                        </div>
                    </header>
                </div>

                <div class="p-8 lg:p-10 space-y-5">
                    <p class="text-sm leading-relaxed text-dark">
                        Master Class de 3 horas + e-book SELF-TAUGHT ENGLISH
                        incluido para cada participante. Formato presencial o en
                        linea.
                    </p>

                    <div class="overflow-x-auto -mx-4 sm:mx-0">
                        <table class="min-w-full border-collapse text-left">
                            <thead class="hidden sm:table-header-group">
                                <tr class="border-b border-primary/20">
                                    <th
                                        class="pb-4 px-4 text-xs font-bold uppercase tracking-wider text-dark"
                                    >
                                        Participants
                                    </th>
                                    <th
                                        class="pb-4 px-4 text-xs font-bold uppercase tracking-wider text-dark"
                                    >
                                        Price per person
                                    </th>
                                    <th
                                        class="pb-4 px-4 text-xs font-bold uppercase tracking-wider text-dark text-right"
                                    >
                                        Estimated total
                                    </th>
                                </tr>
                            </thead>

                            <tbody class="divide-y divide-border/60">
                                {
                                    businessPricing.map((row) => (
                                        <tr class="block sm:table-row rounded-xl sm:rounded-none bg-light/40 sm:bg-transparent p-4 sm:p-0 mb-4 sm:mb-0">
                                            {/* Participants */}
                                            <td class="flex justify-between sm:table-cell px-0 sm:px-4 py-2 text-sm font-medium text-dark">
                                                <span class="sm:hidden font-semibold text-primary">
                                                    Participants
                                                </span>
                                                {row.participants}
                                            </td>

                                            {/* Price per person */}
                                            <td class="flex justify-between sm:table-cell px-0 sm:px-4 py-2 text-sm text-dark">
                                                <span class="sm:hidden font-semibold text-primary">
                                                    Price per person
                                                </span>
                                                {row.pricePerPerson}
                                            </td>

                                            {/* Total */}
                                            <td class="flex justify-between sm:table-cell px-0 sm:px-4 py-2 text-base sm:text-lg font-bold text-primary sm:text-right">
                                                <span class="sm:hidden font-semibold text-primary">
                                                    Estimated total
                                                </span>
                                                {row.totalRange}
                                            </td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>

                    <p class="text-xs text-dark">
                        * Workshop attendance limit: 40 people. Special rates
                        apply for large seminars (40+).
                    </p>

                    <a
                        href="mailto:"
                        class="inline-flex items-center gap-2 rounded-lg group bg-primary text-white py-2 px-4 text-sm font-bold shadow-primary/25 hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/30 transition-all cursor-pointer"
                    >
                        Book a session
                        <ArrowRightIcon
                            class="size-4 transition-transform group-hover:translate-x-1"
                        />
                    </a>
                </div>
            </div>
        </div>

        <footer class="mt-10 text-center text-sm text-dark">
            Attendance limit: 40 people in workshops. Special rates for large
            seminars. Contact us for a personalized quote.
        </footer>
    </article>
</section>
