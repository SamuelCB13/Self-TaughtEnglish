---
import { benefits } from "../libs/benefits";
---

<section id="benefits" class="bg-background py-24 lg:py-32">
    <article class="mx-auto max-w-7xl px-6 space-y-12">
        <header class="mx-auto max-w-2xl text-center space-y-5">
            <span
                class="inline-block rounded-full bg-secondary/10 px-4 py-1.5 text-xs font-semibold text-secondary"
            >
                BENEFICIOS
            </span>
            <h2
                class="text-3xl font-bold tracking-tight text-primary sm:text-4xl lg:text-5xl text-balance"
            >
                ¿Por qué esto importa?
            </h2>
            <p
                class="text-base leading-relaxed text-dark lg:text-lg text-pretty"
            >
                Dominar el inglés ya no es un lujo, es una necesidad. Descubre cómo puedes lograrlo de forma rápida, inteligente y sin gastar una fortuna.
            </p>
        </header>

        <ul
            class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8"
        >
            {
                benefits.map((benefit, index) => (
                    <li
                        class="group relative flex flex-col gap-3 rounded-2xl border border-border bg-white p-8 shadow-sm transition-all duration-300 hover:shadow-xl hover:-translate-y-2 hover:border-secondary/30"
                    >
                        <span class="absolute -top-3 -left-3 flex size-8 items-center justify-center rounded-full bg-primary text-sm font-bold text-white shadow-md">
                            {index + 1}
                        </span>

                        <div
                            class={`flex h-14 w-14 items-center justify-center rounded-xl ${benefit.color} transition-transform duration-300 group-hover:scale-110`}
                        >
                            <benefit.icon class="size-7" />
                        </div>
                        <h3 class="text-lg font-bold text-bold">
                            {benefit.title}
                        </h3>
                        <p class="flex-1 text-sm leading-relaxed text-dark">
                            {benefit.description}
                        </p>
                    </li>
                ))
            }
        </ul>
    </article>
</section>
